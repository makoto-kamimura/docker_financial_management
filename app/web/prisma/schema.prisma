// 決算管理システム データモデル
// 参照: docs/design.md「6. データモデル」

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 勘定科目カテゴリ
enum AccountCategory {
  REVENUE  // 売上・収入
  COGS     // 売上原価・変動費
  EXPENSE  // 販管費・固定費
  PROFIT   // 利益・貯蓄
  ASSET    // 資産（貸借対照表）
  LIABILITY // 負債（貸借対照表）
  OTHER
}

// 予測手法
enum ForecastMethod {
  MOVING_AVERAGE
  LINEAR_REGRESSION
  GROWTH_RATE
}

// 予測シナリオ
enum ForecastScenario {
  OPTIMISTIC
  BASE
  PESSIMISTIC
}

// 勘定科目マスタ
model Account {
  id            Int             @id @default(autoincrement())
  tenantId      Int
  code          String
  name          String                          // 既定表示名（家庭モードの科目名）
  soleName      String?                         // 個人事業主モードでの表示科目名（null は name にフォールバック）
  corporateName String?                         // 法人モードでの表示科目名（null は name にフォールバック）
  category  AccountCategory @default(OTHER)
  parentId  Int?            // 親勘定科目 ID（null = トップレベル）
  parent    Account?        @relation("AccountTree", fields: [parentId], references: [id])
  children  Account[]       @relation("AccountTree")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  records              FinancialRecord[]
  forecasts            Forecast[]
  budgets              Budget[]
  linkedAccounts       LinkedAccount[]
  journalDetails       JournalDetail[]
  apportionments       Apportionment[]
  journalTemplateLines JournalTemplateLine[]
  accruedRevenues      AccruedRevenue[]
  accruedExpenses      AccruedExpense[]
  loans                Loan[]
  personalAssets       PersonalAsset[]
  allocationRules      AllocationRule[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("accounts")
}

// 部門 / セグメントマスタ
model Department {
  id       Int          @id @default(autoincrement())
  tenantId Int
  name     String
  manager  String?      // 担当者名
  parentId Int?
  parent   Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children Department[] @relation("DepartmentTree")

  records FinancialRecord[]

  @@index([tenantId])
  @@map("departments")
}

// 会計期間マスタ
model Period {
  id         Int    @id @default(autoincrement())
  tenantId   Int
  fiscalYear Int
  quarter    Int // 1-4
  month      Int // 1-12

  records   FinancialRecord[]
  forecasts Forecast[]
  budgets   Budget[]

  @@unique([tenantId, fiscalYear, month])
  @@index([tenantId])
  @@map("periods")
}

// 予算データ（予実対比に使用）
model Budget {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  account   Account  @relation(fields: [accountId], references: [id])
  accountId Int
  period    Period   @relation(fields: [periodId], references: [id])
  periodId  Int
  amount    Decimal  @db.Decimal(18, 2)
  createdAt DateTime @default(now())

  @@unique([tenantId, accountId, periodId])
  @@index([tenantId])
  @@map("budgets")
}

// 予算配分ルール（FP 推奨の収入比率マスタ。ステップ 2 の配分提案に使用）
// 既定ルール（旧モバイル DEFAULT_ALLOCATION）をテナント作成時に自動投入する。
model AllocationRule {
  id         Int      @id @default(autoincrement())
  tenantId   Int
  key        String                     // ルール識別子（rent / food など）
  label      String                     // 表示名（家賃・住宅ローン など）
  group      String                     // 固定費 / 生活費 / その他
  minPercent Decimal  @db.Decimal(5, 2) // 推奨割合の下限（%）
  maxPercent Decimal? @db.Decimal(5, 2) // 推奨割合の上限（%）。null = 上限なし
  note       String?                    // 補足（「理想は25%以内」など）
  account    Account? @relation(fields: [accountId], references: [id])
  accountId  Int?                       // 対応する支払項目科目（null = 未紐付け）
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("allocation_rules")
}

// 実績データ
model FinancialRecord {
  id           Int         @id @default(autoincrement())
  tenantId     Int
  account      Account     @relation(fields: [accountId], references: [id])
  accountId    Int
  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId Int?
  period       Period      @relation(fields: [periodId], references: [id])
  periodId     Int
  amount       Decimal     @db.Decimal(18, 2)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  history FinancialRecordHistory[]

  @@index([tenantId, accountId, periodId])
  @@map("financial_records")
}

// 実績データ変更履歴（入力・更新・削除の日時とユーザーを記録）
model FinancialRecordHistory {
  id        Int             @id @default(autoincrement())
  record    FinancialRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  recordId  Int
  userId    Int?            // 操作ユーザー（null = CSV インポート等のシステム操作）
  action    String          // "create" | "update" | "delete"
  amount    Decimal         @db.Decimal(18, 2) // 操作時点の金額
  changedAt DateTime        @default(now())

  @@index([recordId])
  @@map("financial_record_histories")
}

// 予測データ
model Forecast {
  id        Int              @id @default(autoincrement())
  tenantId  Int
  account   Account          @relation(fields: [accountId], references: [id])
  accountId Int
  period    Period           @relation(fields: [periodId], references: [id])
  periodId  Int
  method    ForecastMethod   @default(LINEAR_REGRESSION)
  scenario  ForecastScenario @default(BASE)
  amount    Decimal          @db.Decimal(18, 2)
  createdAt DateTime         @default(now())

  @@index([tenantId])
  @@map("forecasts")
}

// 銀行口座・クレジットカード 連携情報
model LinkedAccount {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  name        String               // 口座名・カード名（表示名）
  type        String               // BANK | CREDIT_CARD
  institution String               // 金融機関名
  lastFour    String?              // 口座番号・カード番号の下4桁
  accountId   Int?                 // 紐付く勘定科目（ASSET/LIABILITY）
  account     Account? @relation(fields: [accountId], references: [id])
  note        String?              // メモ
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@map("linked_accounts")
}

// ユーザー（認証）
model User {
  id               Int       @id @default(autoincrement())
  tenantId         Int       // 1テナントに複数ユーザーを所属させられる（N:1）
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  email            String    @unique
  name             String
  passwordHash     String
  role             String    @default("viewer") // admin / editor / accountant / viewer
  mfaEnabled       Boolean   @default(false)
  totpSecret       String?   // Base32 エンコードされた TOTP シークレット
  mfaRecoveryCodes String?   // JSON 配列: ハッシュ化されたリカバリーコード
  loginAttempts    Int       @default(0) // 連続失敗回数
  lockedUntil      DateTime? // アカウントロック解除時刻
  createdAt        DateTime  @default(now())

  sessions         Session[]
  journalApprovals JournalApproval[]

  @@index([tenantId])
  @@map("users")
}

// セッション
model Session {
  id        String   @id
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("sessions")
}

// 監査ログ
model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  target    String
  before    String?  // 変更前の値（JSON）
  after     String?  // 変更後の値（JSON）
  changedAt DateTime @default(now())

  @@map("audit_logs")
}

// 銀行口座の役割
enum BankAccountRole {
  SALARY // 給与口座
  WITHDRAWAL // 引き落とし用口座
  SAVINGS // 貯蓄
  OTHER
}

// 資金移動の種別
enum TransferKind {
  MANUAL // 手動振込
  AUTO // 自動振替 / 自動引き落とし
}

// 資金移動のチャネル（口座引き落とし・カード引き落とし・入金・支出など）
enum TransferChannel {
  BANK_TRANSFER // 口座間振込
  AUTO_DEBIT // 口座引き落とし
  CARD_PAYMENT // クレジットカード引き落とし
  INCOME // 入金（給与等・外部から）
  EXPENSE // 支出（外部へ）
}

// 銀行入出金明細の取得元
enum TxnSource {
  MANUAL // 手入力
  CSV // CSV 取込
  SYNC // 自動同期（アグリゲーション）
}

// ── 個人事業主・確定申告支援 ───────────────────────────────────────────

// F001 事業者情報
model BusinessProfile {
  id              Int       @id @default(autoincrement())
  tenantId        Int       @unique
  tradeName       String?               // 屋号
  ownerName       String    @default("") // 氏名
  openedOn        DateTime?             // 開業日
  blueReturn      Boolean   @default(false) // 青色申告
  invoiceNumber   String?               // インボイス登録番号（T + 13桁）
  taxationType    String    @default("exempt") // exempt / general / simplified
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("business_profiles")
}

// F012 消費税設定（年度別）
model TaxSetting {
  id              Int      @id @default(autoincrement())
  tenantId        Int
  taxYear         Int                   // 適用年度
  taxationType    String                // exempt / general / simplified
  simplifiedRate  Decimal? @db.Decimal(5, 2) // 簡易課税みなし仕入率（%）
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, taxYear])
  @@index([tenantId])
  @@map("tax_settings")
}

// F002 仕訳帳ヘッダ
model JournalEntry {
  id              Int       @id @default(autoincrement())
  tenantId        Int
  transactionDate DateTime              // 取引日
  description     String                // 摘要
  paymentMethod   String    @default("cash") // cash / bank / card / transfer
  taxCategory     String    @default("taxable") // taxable / exempt / non_taxable
  receiptUrl      String?               // 証憑ファイル URL
  approvalStatus  String    @default("approved") // draft / pending / approved / rejected
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  details   JournalDetail[]
  receipts  Receipt[]
  approvals JournalApproval[]

  @@index([tenantId, transactionDate])
  @@index([tenantId, approvalStatus])
  @@map("journal_entries")
}

// 電子帳簿保存法: 仕訳承認ワークフロー
model JournalApproval {
  id             Int          @id @default(autoincrement())
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  journalEntryId Int
  action         String                   // submitted / approved / rejected
  actorId        Int
  actor          User         @relation(fields: [actorId], references: [id])
  comment        String?
  createdAt      DateTime     @default(now())

  @@index([journalEntryId])
  @@map("journal_approvals")
}

// F002 仕訳明細（複式簿記：借方/貸方）
model JournalDetail {
  id                  Int          @id @default(autoincrement())
  journalEntry        JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  journalEntryId      Int
  side                String                // debit（借方）/ credit（貸方）
  account             Account      @relation(fields: [accountId], references: [id])
  accountId           Int
  amount              Decimal      @db.Decimal(18, 2)
  taxRate             Decimal?     @db.Decimal(5, 4)     // 消費税率（0.10 / 0.08 / null=非課税）
  taxCreditEligible   Boolean      @default(true)        // 仕入税額控除対象か
  note                String?                            // 明細摘要

  @@index([journalEntryId])
  @@map("journal_details")
}

// F005 証憑ファイル
model Receipt {
  id             Int          @id @default(autoincrement())
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  journalEntryId Int
  fileName       String                 // アップロード時の元ファイル名（表示用）
  fileUrl        String                 // 配信 URL（/api/uploads/<savedName>）
  savedName      String?                // uploads/ 配下の実ファイル名（配信時の所有確認・Content-Type 決定に使用）
  mimeType       String?                // アップロード時に検証済みの MIME タイプ
  fileType       String       // pdf / image / other
  fileSize       Int
  uploadedAt     DateTime     @default(now())

  @@unique([savedName])
  @@index([journalEntryId])
  @@map("receipts")
}

// F006 棚卸帳ヘッダ
model Inventory {
  id               Int             @id @default(autoincrement())
  tenantId         Int
  name             String          // 棚卸名（例: 2026年6月末棚卸）
  inventoryDate    DateTime        // 棚卸日
  status           String          @default("open") // open / closed
  totalAmount      Decimal         @default(0) @db.Decimal(18, 2)
  valuationMethod  String          @default("last_purchase") // last_purchase / average / moving_average
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  items InventoryItem[]

  @@index([tenantId, inventoryDate])
  @@map("inventories")
}

// F006 棚卸明細
model InventoryItem {
  id          Int       @id @default(autoincrement())
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  inventoryId Int
  itemName    String
  itemType    String    @default("product") // product / material / wip / goods
  quantity    Decimal   @db.Decimal(10, 3)
  unit        String    @default("個")
  unitPrice   Decimal   @db.Decimal(18, 2)
  totalAmount Decimal   @db.Decimal(18, 2) // quantity × unitPrice
  createdAt   DateTime  @default(now())

  @@index([inventoryId])
  @@map("inventory_items")
}

// F007 固定資産台帳
model FixedAsset {
  id              Int       @id @default(autoincrement())
  tenantId        Int
  name            String    // 資産名
  category        String    @default("tangible") // tangible / intangible
  acquiredOn      DateTime  // 取得日
  acquisitionCost Decimal   @db.Decimal(18, 2)   // 取得金額
  usefulLife      Int       // 耐用年数（年）
  method          String    @default("straight")  // straight（定額）/ declining（定率）
  residualRate    Decimal   @default(0.1) @db.Decimal(5, 4) // 残存率（旧定率法）
  bookValue       Decimal   @db.Decimal(18, 2)   // 帳簿価額
  disposedOn      DateTime?                       // 除却・売却日
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  depreciations Depreciation[]

  @@index([tenantId])
  @@map("fixed_assets")
}

// F008 減価償却明細
model Depreciation {
  id           Int        @id @default(autoincrement())
  fixedAsset   FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)
  fixedAssetId Int
  fiscalYear   Int
  amount       Decimal    @db.Decimal(18, 2) // 年間償却費
  createdAt    DateTime   @default(now())

  @@unique([fixedAssetId, fiscalYear])
  @@index([fixedAssetId])
  @@map("depreciations")
}

// 実物資産の分類（土地・建物・車・金など）
enum PersonalAssetCategory {
  LAND      // 土地
  BUILDING  // 建物
  VEHICLE   // 車
  GOLD      // 金・貴金属
  OTHER
}

// 実物資産台帳（家計の資産管理: 土地・建物・車・金など）
model PersonalAsset {
  id              Int                   @id @default(autoincrement())
  tenantId        Int
  name            String                            // 資産名（例: 自宅土地）
  category        PersonalAssetCategory @default(OTHER)
  acquiredOn      DateTime?                         // 取得日
  acquisitionCost Decimal?              @db.Decimal(18, 2) // 取得価格
  currentValue    Decimal               @db.Decimal(18, 2) // 現在評価額
  note            String?
  linkedAccountId Int?                                      // 紐付く負債科目（例: 住宅ローン）
  linkedAccount   Account?              @relation(fields: [linkedAccountId], references: [id])
  debtStartOn       DateTime?                               // 負債の支払い開始年月。月初日で保存
  debtPayoffDue     DateTime?                               // 負債解消（完済）予定年月。月初日で保存
  debtInitialAmount Decimal?              @db.Decimal(18, 2) // 当初負債額。開始月〜解消予定月で月割りして予算に自動計上し、経過月数から残高を算出
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([tenantId])
  @@index([linkedAccountId])
  @@map("personal_assets")
}

// F009 家事按分設定
model Apportionment {
  id           Int      @id @default(autoincrement())
  tenantId     Int
  account      Account  @relation(fields: [accountId], references: [id])
  accountId    Int
  businessRate Decimal  @db.Decimal(5, 2) // 事業利用率（%）
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, accountId])
  @@index([tenantId])
  @@map("apportionments")
}

// F010 売掛金管理
model Receivable {
  id            Int       @id @default(autoincrement())
  tenantId      Int
  customerName  String                       // 得意先名
  description   String                       // 件名・摘要
  amount        Decimal   @db.Decimal(18, 2) // 請求金額（税込）
  taxAmount     Decimal   @default(0) @db.Decimal(18, 2)
  issueDate     DateTime                     // 請求日
  dueDate       DateTime                     // 支払期限
  status        String    @default("open")   // open / paid / overdue
  paidOn        DateTime?                    // 入金日
  paidAmount    Decimal?  @db.Decimal(18, 2) // 入金金額
  invoiceNumber String?                      // 請求書番号
  note          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId, dueDate])
  @@index([tenantId, status])
  @@map("receivables")
}

// F011 買掛金管理
model Payable {
  id           Int       @id @default(autoincrement())
  tenantId     Int
  supplierName String                       // 仕入先名
  description  String                       // 件名・摘要
  amount       Decimal   @db.Decimal(18, 2) // 請求金額（税込）
  taxAmount    Decimal   @default(0) @db.Decimal(18, 2)
  issueDate    DateTime                     // 請求書受取日
  dueDate      DateTime                     // 支払期限
  status       String    @default("open")   // open / paid / overdue
  paidOn       DateTime?                    // 支払日
  paidAmount   Decimal?  @db.Decimal(18, 2) // 支払金額
  note         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([tenantId, dueDate])
  @@index([tenantId, status])
  @@map("payables")
}

// ============================================================
// 法人・統合会計 — Phase 1: マルチテナント基盤
// ============================================================

// テナント（法人 / 個人事業主）
model Tenant {
  id              Int       @id @default(autoincrement())
  type            String    @default("SOLE_PROPRIETOR") // SOLE_PROPRIETOR / CORPORATION
  name            String                                // 屋号または法人名
  corporateNumber String?                               // 法人番号 13 桁
  capitalAmount   Decimal?  @db.Decimal(18, 2)          // 資本金
  establishedOn   DateTime?
  closingMonth    Int       @default(12)                // 決算月（1-12）
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  users             User[]
  fiscalYears       FiscalYear[]
  officers          Officer[]
  meetings          ShareholderMeeting[]
  dividends         Dividend[]
  announcements     Announcement[]

  @@map("tenants")
}

// 会計年度（テナント別）
model FiscalYear {
  id        Int      @id @default(autoincrement())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId  Int
  year      Int
  startDate DateTime
  endDate   DateTime
  status    String   @default("open") // open / closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, year])
  @@map("fiscal_years")
}

// ============================================================
// 法人・統合会計 — Phase 2: 会計帳簿機能強化
// ============================================================

// 仕訳テンプレート
model JournalTemplate {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines JournalTemplateLine[]

  @@index([tenantId])
  @@map("journal_templates")
}

model JournalTemplateLine {
  id         Int             @id @default(autoincrement())
  template   JournalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId Int
  side       String          // debit / credit
  account    Account         @relation(fields: [accountId], references: [id])
  accountId  Int
  amount     Decimal?        @db.Decimal(18, 2) // null = 入力時に指定
  note       String?
  sortOrder  Int             @default(0)

  @@map("journal_template_lines")
}

// ============================================================
// 法人・統合会計 — Phase 3: 在庫・銀行・借入金管理
// ============================================================

// 銀行口座
model BankAccount {
  id          Int             @id @default(autoincrement())
  tenantId    Int
  name        String          // 表示名（例: 給与口座）
  bankName    String          // 銀行名
  branchName  String?         // 支店名
  accountType String          @default("普通") // 普通 / 当座
  role        BankAccountRole @default(OTHER)
  createdAt   DateTime        @default(now())

  outgoing     Transfer[]        @relation("from")
  incoming     Transfer[]        @relation("to")
  transactions BankTransaction[]

  @@index([tenantId])
  @@map("bank_accounts")
}

// 資金移動ルール（振込 / 口座引き落とし / カード引き落とし / 入金 / 支出）
// fromAccountId / toAccountId は null 可（null = 外部＝給与・カード会社・各種支出先）
model Transfer {
  id            Int             @id @default(autoincrement())
  tenantId      Int
  fromAccount   BankAccount?    @relation("from", fields: [fromAccountId], references: [id])
  fromAccountId Int?
  toAccount     BankAccount?    @relation("to", fields: [toAccountId], references: [id])
  toAccountId   Int?
  amount        Decimal         @db.Decimal(18, 2)
  kind          TransferKind    @default(AUTO)
  channel       TransferChannel @default(BANK_TRANSFER)
  label         String? // 外部側の名称（例: 給与、◯◯カード、家賃）
  day           Int // 振込日 / 引き落とし日 (1-31)
  note          String?
  createdAt     DateTime        @default(now())

  @@index([tenantId])
  @@index([fromAccountId])
  @@index([toAccountId])
  @@map("transfers")
}

// 銀行入出金明細（取込・同期したトランザクション）
model BankTransaction {
  id          Int         @id @default(autoincrement())
  account     BankAccount @relation(fields: [accountId], references: [id])
  accountId   Int
  date        DateTime    // 取引日
  description String      // 摘要
  amount      Decimal     @db.Decimal(18, 2) // +入金 / -出金
  balance     Decimal?    @db.Decimal(18, 2) // 取引後残高（取得できた場合）
  source      TxnSource   @default(MANUAL)
  externalId  String?     // 重複取込防止用の外部ID
  createdAt   DateTime    @default(now())

  @@unique([accountId, externalId])
  @@index([accountId, date])
  @@map("bank_transactions")
}

// 借入金
model Loan {
  id              Int       @id @default(autoincrement())
  tenantId        Int
  lenderName      String
  amount          Decimal   @db.Decimal(18, 2)
  interestRate    Decimal   @db.Decimal(5, 4)
  borrowedOn      DateTime
  repaymentDate   DateTime                       // 完済予定/支払い完了年月
  remainingAmount Decimal   @db.Decimal(18, 2)
  status          String    @default("active") // active / repaid
  note            String?
  loanType        String    @default("business") // business（事業性）/ housing（住宅ローン）
  linkedAccountId Int?                            // 住宅ローン: 返済額を自動反映する予算科目（例: 家賃）
  linkedAccount   Account?  @relation(fields: [linkedAccountId], references: [id])
  monthlyPayment  Decimal?  @db.Decimal(18, 2)    // 住宅ローン: 月々の返済額（予算に自動加算）
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  repayments LoanRepayment[]

  @@index([tenantId])
  @@index([linkedAccountId])
  @@map("loans")
}

model LoanRepayment {
  id          Int      @id @default(autoincrement())
  loan        Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  loanId      Int
  repaidOn    DateTime
  principal   Decimal  @db.Decimal(18, 2)
  interest    Decimal  @db.Decimal(18, 2)
  totalAmount Decimal  @db.Decimal(18, 2)
  createdAt   DateTime @default(now())

  @@index([loanId])
  @@map("loan_repayments")
}

