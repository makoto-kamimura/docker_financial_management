// 決算管理システム データモデル
// 参照: docs/design.md「6. データモデル」

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 勘定科目カテゴリ
enum AccountCategory {
  REVENUE // 売上
  COGS // 売上原価
  EXPENSE // 販管費
  PROFIT // 利益
  OTHER
}

// 予測手法
enum ForecastMethod {
  MOVING_AVERAGE
  LINEAR_REGRESSION
  GROWTH_RATE
}

// 予測シナリオ
enum ForecastScenario {
  OPTIMISTIC
  BASE
  PESSIMISTIC
}

// 勘定科目マスタ
model Account {
  id        Int             @id @default(autoincrement())
  code      String          @unique
  name      String
  category  AccountCategory @default(OTHER)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  records   FinancialRecord[]
  forecasts Forecast[]
  budgets   Budget[]

  @@map("accounts")
}

// 部門 / セグメントマスタ
model Department {
  id       Int          @id @default(autoincrement())
  name     String
  parentId Int?
  parent   Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children Department[] @relation("DepartmentTree")

  records FinancialRecord[]

  @@map("departments")
}

// 会計期間マスタ
model Period {
  id         Int    @id @default(autoincrement())
  fiscalYear Int
  quarter    Int // 1-4
  month      Int // 1-12

  records   FinancialRecord[]
  forecasts Forecast[]
  budgets   Budget[]

  @@unique([fiscalYear, month])
  @@map("periods")
}

// 予算データ（予実対比に使用）
model Budget {
  id        Int      @id @default(autoincrement())
  account   Account  @relation(fields: [accountId], references: [id])
  accountId Int
  period    Period   @relation(fields: [periodId], references: [id])
  periodId  Int
  amount    Decimal  @db.Decimal(18, 2)
  createdAt DateTime @default(now())

  @@unique([accountId, periodId])
  @@map("budgets")
}

// 実績データ
model FinancialRecord {
  id           Int         @id @default(autoincrement())
  account      Account     @relation(fields: [accountId], references: [id])
  accountId    Int
  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId Int?
  period       Period      @relation(fields: [periodId], references: [id])
  periodId     Int
  amount       Decimal     @db.Decimal(18, 2)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([accountId, periodId])
  @@map("financial_records")
}

// 予測データ
model Forecast {
  id        Int              @id @default(autoincrement())
  account   Account          @relation(fields: [accountId], references: [id])
  accountId Int
  period    Period           @relation(fields: [periodId], references: [id])
  periodId  Int
  method    ForecastMethod   @default(LINEAR_REGRESSION)
  scenario  ForecastScenario @default(BASE)
  amount    Decimal          @db.Decimal(18, 2)
  createdAt DateTime         @default(now())

  @@map("forecasts")
}

// ユーザー（認証）
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("viewer") // admin / editor / viewer
  mfaEnabled   Boolean  @default(false)
  totpSecret   String? // Base32 エンコードされた TOTP シークレット
  createdAt    DateTime @default(now())

  sessions Session[]

  @@map("users")
}

// セッション
model Session {
  id        String   @id
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("sessions")
}

// 監査ログ
model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  target    String
  changedAt DateTime @default(now())

  @@map("audit_logs")
}

// 銀行口座の役割
enum BankAccountRole {
  SALARY // 給与口座
  WITHDRAWAL // 引き落とし用口座
  SAVINGS // 貯蓄
  OTHER
}

// 資金移動の種別
enum TransferKind {
  MANUAL // 手動振込
  AUTO // 自動振替 / 自動引き落とし
}

// 資金移動のチャネル（口座引き落とし・カード引き落とし・入金・支出など）
enum TransferChannel {
  BANK_TRANSFER // 口座間振込
  AUTO_DEBIT // 口座引き落とし
  CARD_PAYMENT // クレジットカード引き落とし
  INCOME // 入金（給与等・外部から）
  EXPENSE // 支出（外部へ）
}

// 銀行入出金明細の取得元
enum TxnSource {
  MANUAL // 手入力
  CSV // CSV 取込
  SYNC // 自動同期（アグリゲーション）
}

// 銀行口座
model BankAccount {
  id          Int             @id @default(autoincrement())
  name        String // 表示名（例: 給与口座）
  bankName    String // 銀行名
  branchName  String? // 支店名
  accountType String          @default("普通") // 普通 / 当座
  role        BankAccountRole @default(OTHER)
  createdAt   DateTime        @default(now())

  outgoing     Transfer[]        @relation("from")
  incoming     Transfer[]        @relation("to")
  transactions BankTransaction[]

  @@map("bank_accounts")
}

// 資金移動ルール（振込 / 口座引き落とし / カード引き落とし / 入金 / 支出）
// fromAccountId / toAccountId は null 可（null = 外部＝給与・カード会社・各種支出先）
model Transfer {
  id            Int             @id @default(autoincrement())
  fromAccount   BankAccount?    @relation("from", fields: [fromAccountId], references: [id])
  fromAccountId Int?
  toAccount     BankAccount?    @relation("to", fields: [toAccountId], references: [id])
  toAccountId   Int?
  amount        Decimal         @db.Decimal(18, 2)
  kind          TransferKind    @default(AUTO)
  channel       TransferChannel @default(BANK_TRANSFER)
  label         String? // 外部側の名称（例: 給与、◯◯カード、家賃）
  day           Int // 振込日 / 引き落とし日 (1-31)
  note          String?
  createdAt     DateTime        @default(now())

  @@index([fromAccountId])
  @@index([toAccountId])
  @@map("transfers")
}

// 銀行入出金明細（取込・同期したトランザクション）
model BankTransaction {
  id          Int         @id @default(autoincrement())
  account     BankAccount @relation(fields: [accountId], references: [id])
  accountId   Int
  date        DateTime // 取引日
  description String // 摘要
  amount      Decimal     @db.Decimal(18, 2) // +入金 / -出金
  balance     Decimal?    @db.Decimal(18, 2) // 取引後残高（取得できた場合）
  source      TxnSource   @default(MANUAL)
  externalId  String? // 重複取込防止用の外部ID
  createdAt   DateTime    @default(now())

  @@unique([accountId, externalId])
  @@index([accountId, date])
  @@map("bank_transactions")
}
