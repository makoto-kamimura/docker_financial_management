// ============================================================
// 家庭 ↔ 法人 勘定科目変換システム
// 参照: docs/account-conversion-system.md
// ============================================================

enum AccountMappingMatchType {
  TABLE    // 変換テーブル直引き（定義済みH-prefix科目）
  KEYWORD  // キーワードルール（「税」「保険」等）
  FUZZY    // あいまい一致（類似度スコア）
  AI_FREE  // AI推論（無料・軽量モデル）
  AI_PAID  // AI推論（有料・高精度モデル）
  MANUAL   // ユーザー手動マッピング
}

enum AccountConversionMode {
  HOME
  CORPORATE
}

enum AccountConversionStatus {
  COMPLETED
  CANCELLED
}

// 勘定科目変換ルールマスタ（システム定義 + ユーザー独自ルール）
model AccountMappingRule {
  id              Int                    @id @default(autoincrement())
  homeCode        String                 // 家庭モード科目コード（H-prefix）
  corporateCode   String?                // 法人科目コード（変換不可の場合 null）
  matchType       AccountMappingMatchType @default(TABLE)
  confidenceScore Float                  @default(1.0) // 0.0〜1.0
  isConvertible   Boolean                @default(true) // false = 変換不可（❌科目）
  notes           String?                // 調整区分・税務注意事項等のメモ
  userId          Int?                   // null = システム定義、値あり = ユーザー独自ルール
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([homeCode, userId])
  @@index([homeCode])
  @@index([userId])
  @@map("account_mapping_rules")
}

// 変換セッション（モード切替ごとに1レコード）
model AccountConversionSession {
  id          Int                      @id @default(autoincrement())
  userId      Int
  fromMode    AccountConversionMode
  toMode      AccountConversionMode
  convertedAt DateTime                 @default(now())
  status      AccountConversionStatus  @default(COMPLETED)

  logs AccountConversionLog[]

  @@index([userId])
  @@map("account_conversion_sessions")
}

// 変換ログ（セッション内の科目ごとの変換結果）
model AccountConversionLog {
  id                   Int                      @id @default(autoincrement())
  session              AccountConversionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId            Int
  homeAccountId        Int                      // 変換元科目（Account.id）
  corporateAccountId   Int?                     // 変換先科目（変換不可の場合 null）
  matchType            AccountMappingMatchType
  confidenceScore      Float?                   // 信頼度スコア（0.0〜1.0）
  isConvertible        Boolean                  @default(true)
  isManuallyOverridden Boolean                  @default(false)
  createdAt            DateTime                 @default(now())

  @@index([sessionId])
  @@map("account_conversion_logs")
}

// AI有料変換結果キャッシュ（30日間再利用）
model AiConversionResult {
  id                 Int      @id @default(autoincrement())
  cacheKey           String   @unique // SHA256(accountName + ":" + businessType)
  inputContext       Json              // AIに渡したコンテキスト全体
  primaryCode        String            // 推奨変換先科目コード
  primaryReason      String            // 選択理由
  taxClassification  String            // 課税 / 非課税 / 免税 / 不課税
  taxNotes           String?           // 税務上の注意事項
  alternatives       Json              // 代替候補リスト
  confidenceScore    Float             // 信頼度スコア（0.0〜1.0）
  confidenceReason   String            // 信頼度の根拠説明
  warnings           Json              // 注意事項リスト
  modelId            String            // 使用したLLMモデルID
  cachedUntil        DateTime          // キャッシュ有効期限（30日）
  createdAt          DateTime @default(now())

  @@map("ai_conversion_results")
}

// AI有料変換利用履歴・課金ログ
model AiConversionUsage {
  id              Int      @id @default(autoincrement())
  userId          Int
  sessionId       Int
  accountCount    Int              // 変換対象科目数
  cachedCount     Int              // キャッシュヒット数（課金対象外）
  billedCount     Int              // 実際にAPI呼び出しした科目数
  plan            String           // PAY_PER_USE / MONTHLY
  chargedAt       DateTime         @default(now())
  reportGenerated Boolean          @default(false)

  @@index([userId])
  @@index([sessionId])
  @@map("ai_conversion_usages")
}

